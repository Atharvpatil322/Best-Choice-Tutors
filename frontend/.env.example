# Frontend Environment Variables

# Backend API Base URL
VITE_API_BASE_URL=http://localhost:5000/api

# Public base URL for static images served from S3 (logo, hero, subject tiles, etc.).
# No trailing slash. Example: https://your-bucket.s3.eu-west-2.amazonaws.com
# Vite only reads env from this file when you run npm from frontend/ — not from the repo root .env
# After changing, restart: npm run dev
VITE_S3_BASE_URL=

# Private S3 (recommended): backend asset proxy base URL.
# If set, images will load via <VITE_ASSET_BASE_URL>/images/...
# Example: https://api.your-domain.com/api/public/assets
VITE_ASSET_BASE_URL=

# Google OAuth Client ID (for Google Sign-In)
# Get this from Google Cloud Console
VITE_GOOGLE_CLIENT_ID=814334113042-rsq1a0s25u9i2ceeqsj5re07b0olmphk.apps.googleusercontent.com
